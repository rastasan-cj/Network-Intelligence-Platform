# ============================================================
# 249-NIP Backend — Production Environment Template
# ============================================================
# Fill in ALL values, rename to .env, then upload to the server.
# NEVER commit this file with real credentials.

# Application
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.YOUR-DOMAIN.com
APP_VERSION=0.1.0

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nip_db
DB_USER=nip_user
DB_PASS=CHANGE_THIS_STRONG_PASSWORD

# JWT — generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_SECRET_MIN_64_CHARS
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
JWT_ALGORITHM=HS256

# CORS — your production frontend URL
CORS_ALLOWED_ORIGINS=https://YOUR-DOMAIN.com

# Mail (SMTP)
MAIL_HOST=smtp.YOUR-PROVIDER.com
MAIL_PORT=587
MAIL_USER=YOUR_SMTP_USERNAME
MAIL_PASS=YOUR_SMTP_PASSWORD
MAIL_FROM_EMAIL=noreply@YOUR-DOMAIN.com
MAIL_FROM_NAME=249-NIP

# File Storage
STORAGE_PATH=/var/www/249-nip/backend/storage
MAX_UPLOAD_SIZE_MB=10

# Security
BCRYPT_COST=12
