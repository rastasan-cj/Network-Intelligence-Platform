# Application
APP_NAME="Network Intelligence Platform"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nip_db
DB_USER=root
DB_PASS=

# JWT
JWT_SECRET=change_this_to_a_strong_random_secret_256bits
JWT_ACCESS_EXPIRE=900
JWT_REFRESH_EXPIRE=604800
JWT_ALGO=HS256

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5000

# Security
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60
