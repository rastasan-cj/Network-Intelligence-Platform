# Block direct access to sensitive files
<Files "config.php">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</Files>
<Files "schema.sql">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</Files>
<Files "create_admin.php">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</Files>

# Route all requests through index.php
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /api/

  # Allow index.php directly
  RewriteRule ^index\.php$ - [L]

  # Block direct PHP access except index.php
  RewriteRule ^(?!index\.php$).*\.php$ - [F,L]

  # Route everything else to index.php
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^ index.php [QSA,L]
</IfModule>

Options -Indexes
